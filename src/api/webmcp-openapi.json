{
  "openapi": "3.0.0",
  "info": {
    "title": "AI Order Management WebMCP API",
    "version": "1.0.0"
  },
  "paths": {
    "/create-order": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create an order",
        "description": "Create a new customer order. Requires support or admin role.",
        "tags": ["orders:write"],
        "x-webmcp-scopes": ["orders:write"],
        "x-webmcp-roles": ["support", "admin"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["customer_name", "amount"],
                "properties": {
                  "customer_name": { "type": "string", "description": "Customer or account name" },
                  "amount": { "type": "number", "description": "Order amount in dollars" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Created order" },
          "403": { "description": "Permission denied" }
        }
      }
    },
    "/update-order-status": {
      "post": {
        "operationId": "updateOrderStatus",
        "summary": "Update order status",
        "description": "Update an existing order status. Requires support or admin role.",
        "tags": ["orders:write"],
        "x-webmcp-scopes": ["orders:write"],
        "x-webmcp-roles": ["support", "admin"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "status"],
                "properties": {
                  "id": { "type": "string", "description": "Order UUID" },
                  "status": {
                    "type": "string",
                    "description": "New order status",
                    "enum": ["pending", "processing", "fulfilled", "cancelled"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated order" },
          "403": { "description": "Permission denied" }
        }
      }
    },
    "/search-orders": {
      "post": {
        "operationId": "searchOrders",
        "summary": "Search orders",
        "description": "Search orders by customer name. Available to authenticated viewer, support, and admin users.",
        "tags": ["orders:read"],
        "x-webmcp-scopes": ["orders:read"],
        "x-webmcp-roles": ["viewer", "support", "admin"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": { "type": "string", "description": "Customer search text" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Matching orders" },
          "403": { "description": "Permission denied" }
        }
      }
    },
    "/delete-order": {
      "post": {
        "operationId": "deleteOrder",
        "summary": "Delete an order",
        "description": "Delete an order. Requires admin role.",
        "tags": ["admin"],
        "x-webmcp-scopes": ["admin:delete"],
        "x-webmcp-roles": ["admin"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "description": "Order UUID" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Delete result" },
          "403": { "description": "Permission denied" }
        }
      }
    },
    "/approve-refund": {
      "post": {
        "operationId": "approveRefund",
        "summary": "Approve refund",
        "description": "Mark an order refund as approved. Requires admin role.",
        "tags": ["admin"],
        "x-webmcp-scopes": ["admin:refund"],
        "x-webmcp-roles": ["admin"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "description": "Order UUID" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated order" },
          "403": { "description": "Permission denied" }
        }
      }
    },
    "/update-quota": {
      "post": {
        "operationId": "updateQuota",
        "summary": "Update customer quota",
        "description": "Update an application user's quota. Requires admin role.",
        "tags": ["admin"],
        "x-webmcp-scopes": ["admin:quota"],
        "x-webmcp-roles": ["admin"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id", "quota"],
                "properties": {
                  "user_id": { "type": "string", "description": "Application user UUID" },
                  "quota": { "type": "number", "description": "New quota value" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated user" },
          "403": { "description": "Permission denied" }
        }
      }
    }
  }
}
